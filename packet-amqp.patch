+static int
+dissect_amqp_0_9_method_connection_update_secret(tvbuff_t* tvb,
+    packet_info* pinfo, int offset, proto_tree* args_tree)
+{
+    uint32_t secret_len;
+    int secret_offset;
+    const uint8_t* secret;
+    proto_item* secret_ti;
+    proto_tree* jwt_tree;
+
+    amqp_mark_modified_build(args_tree, tvb);
+
+    /* new-secret is longstr: 4-byte length + bytes */
+    secret_len = tvb_get_ntohl(tvb, offset);
+    secret_offset = offset + 4;
+
+    secret_ti = proto_tree_add_item_ret_string(args_tree,
+        hf_amqp_method_connection_update_secret_new_secret,
+        tvb, secret_offset, secret_len,
+        ENC_ASCII | ENC_NA, pinfo->pool, &secret);
+
+    if (amqp_secret_looks_like_jwt((const char*)secret)) {
+        jwt_tree = proto_item_add_subtree(secret_ti, ett_amqp_jwt);
+        dissect_amqp_jwt(jwt_tree, tvb, pinfo, secret_offset, (const char*)secret);
+    }
+
+    offset += 4 + secret_len;
+
+    /* reason is shortstr: 1-byte length + bytes */
+    proto_tree_add_item(args_tree,
+        hf_amqp_method_connection_update_secret_reason,
+        tvb, offset + 1, tvb_get_uint8(tvb, offset),
+        ENC_ASCII | ENC_NA);
+
+    offset += 1 + tvb_get_uint8(tvb, offset);
+
+    return offset;
+}
