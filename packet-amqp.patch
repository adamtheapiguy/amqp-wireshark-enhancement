+static void
+dissect_amqp_jwt(proto_tree* tree, tvbuff_t* tvb, packet_info* pinfo,
+    int secret_offset, const char* jwt)
+{
+    const char* p1, * p2;
+    size_t header_len, payload_len, sig_len;
+    int payload_offset;
+    char* header_b64, * payload_b64, * sig_b64;
+    char* header_json, * payload_json;
+    char* header_pretty, * payload_pretty;
+    proto_item* header_ti, * payload_ti;
+    proto_tree* header_tree, * payload_tree;
+
+    p1 = strchr(jwt, '.');
+    if (!p1)
+        return;
+
+    p2 = strchr(p1 + 1, '.');
+    if (!p2)
+        return;
+
+    header_len = p1 - jwt;
+    payload_len = p2 - p1 - 1;
+    sig_len = strlen(p2 + 1);
+    payload_offset = secret_offset + (int)header_len + 1;
+
+    header_b64 = wmem_strndup(pinfo->pool, jwt, header_len);
+    payload_b64 = wmem_strndup(pinfo->pool, p1 + 1, payload_len);
+    sig_b64 = wmem_strndup(pinfo->pool, p2 + 1, sig_len);
+
+    proto_tree_add_string(tree, hf_amqp_jwt_header_b64,
+        tvb, secret_offset, (int)header_len, header_b64);
+
+    proto_tree_add_string(tree, hf_amqp_jwt_payload_b64,
+        tvb, payload_offset, (int)payload_len, payload_b64);
+
+    proto_tree_add_string(tree, hf_amqp_jwt_signature_b64,
+        tvb, payload_offset + (int)payload_len + 1,
+        (int)sig_len, sig_b64);
+
+    header_json = amqp_base64url_decode_to_string(pinfo->pool,
+        header_b64, header_len);
+
+    payload_json = amqp_base64url_decode_to_string(pinfo->pool,
+        payload_b64, payload_len);
+
+    if (header_json) {
+        header_pretty = amqp_pretty_json(pinfo->pool, header_json);
+
+        header_ti = proto_tree_add_string_format(tree,
+            hf_amqp_jwt_header_json,
+            tvb,
+            secret_offset,
+            (int)header_len,
+            header_pretty,
+            "JWT Header JSON Pretty:\n%s",
+            header_pretty);
+
+        header_tree = proto_item_add_subtree(header_ti, ett_amqp_jwt_header);
+
+        amqp_add_json_top_level_claims(header_tree, tvb, secret_offset,
+            (int)header_len, header_json);
+    }
+
+    if (payload_json) {
+        payload_pretty = amqp_pretty_json(pinfo->pool, payload_json);
+
+        payload_ti = proto_tree_add_string_format(tree,
+            hf_amqp_jwt_payload_json,
+            tvb,
+            payload_offset,
+            (int)payload_len,
+            payload_pretty,
+            "JWT Payload JSON Pretty:\n%s",
+            payload_pretty);
+
+        payload_tree = proto_item_add_subtree(payload_ti, ett_amqp_jwt_payload);
+
+        amqp_add_json_top_level_claims(payload_tree, tvb, payload_offset,
+            (int)payload_len, payload_json);
+    }
+}
