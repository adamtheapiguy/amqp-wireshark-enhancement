+static char*
+amqp_pretty_json(wmem_allocator_t* pool, const char* json)
+{
+    size_t len;
+    char* out;
+    int indent = 0;
+    int j = 0;
+    bool in_string = false;
+    bool escape = false;
+    size_t i;
+
+    if (!json)
+        return NULL;
+
+    len = strlen(json);
+    out = (char*)wmem_alloc0(pool, (len * 4) + 1);
+
+    for (i = 0; i < len; i++) {
+        char c = json[i];
+
+        if (escape) {
+            out[j++] = c;
+            escape = false;
+            continue;
+        }
+
+        if (c == '\\' && in_string) {
+            out[j++] = c;
+            escape = true;
+            continue;
+        }
+
+        if (c == '"') {
+            out[j++] = c;
+            in_string = !in_string;
+            continue;
+        }
+
+        if (!in_string && (c == '{' || c == '[')) {
+            out[j++] = c;
+            out[j++] = '\n';
+            indent++;
+            for (int k = 0; k < indent * 2; k++)
+                out[j++] = ' ';
+        }
+        else if (!in_string && c == ',') {
+            out[j++] = c;
+            out[j++] = '\n';
+            for (int k = 0; k < indent * 2; k++)
+                out[j++] = ' ';
+        }
+        else if (!in_string && (c == '}' || c == ']')) {
+            out[j++] = '\n';
+            if (indent > 0)
+                indent--;
+            for (int k = 0; k < indent * 2; k++)
+                out[j++] = ' ';
+            out[j++] = c;
+        }
+        else if (!in_string && c == ':') {
+            out[j++] = c;
+            out[j++] = ' ';
+        }
+        else {
+            out[j++] = c;
+        }
+    }
+
+    out[j] = '\0';
+    return out;
+}
+
+static void
+amqp_add_json_top_level_claims(proto_tree* tree, tvbuff_t* tvb,
+    int offset, int len, const char* json)
+{
+    const char* p = json;
+
+    while ((p = strchr(p, '"')) != NULL) {
+        const char* key_start = p + 1;
+        const char* key_end = strchr(key_start, '"');
+        const char* colon;
+        const char* value_start;
+        const char* value_end;
+        char* key;
+        char* value;
+
+        if (!key_end)
+            break;
+
+        colon = strchr(key_end + 1, ':');
+        if (!colon)
+            break;
+
+        value_start = colon + 1;
+        while (*value_start && g_ascii_isspace(*value_start))
+            value_start++;
+
+        if (*value_start == '"') {
+            value_start++;
+            value_end = value_start;
+            while (*value_end) {
+                if (*value_end == '"' && *(value_end - 1) != '\\')
+                    break;
+                value_end++;
+            }
+        }
+        else {
+            value_end = value_start;
+            while (*value_end && *value_end != ',' && *value_end != '}')
+                value_end++;
+        }
+
+        key = wmem_strndup(wmem_file_scope(), key_start, key_end - key_start);
+        value = wmem_strndup(wmem_file_scope(), value_start, value_end - value_start);
+
+        if (strcmp(key, "scope") == 0) {
+            proto_item* scope_ti;
+            proto_tree* scope_tree;
+
+            scope_ti = proto_tree_add_string(tree,
+                hf_amqp_jwt_claim_scope,
+                tvb, offset, len,
+                value);
+
+            proto_item_set_text(scope_ti, "scope: %s", value);
+
+            scope_tree = proto_item_add_subtree(scope_ti, ett_amqp_jwt_payload);
+
+            amqp_add_scope_items(scope_tree, tvb, offset, len, value);
+        }
+        else {
+            if (strcmp(key, "exp") == 0 ||
+                strcmp(key, "iat") == 0 ||
+                strcmp(key, "nbf") == 0 ||
+                strcmp(key, "auth_time") == 0) {
+
+                char* time_value;
+
+                time_value = amqp_epoch_to_local_time_string(wmem_file_scope(), value);
