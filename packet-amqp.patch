+static char*
+amqp_base64url_to_base64(wmem_allocator_t* pool, const char* in, size_t len)
+{
+    size_t pad;
+    char* out;
+
+    pad = (4 - (len % 4)) % 4;
+    out = (char*)wmem_alloc0(pool, len + pad + 1);
+
+    memcpy(out, in, len);
+
+    for (size_t i = 0; i < len; i++) {
+        if (out[i] == '-')
+            out[i] = '+';
+        else if (out[i] == '_')
+            out[i] = '/';
+    }
+
+    for (size_t i = 0; i < pad; i++) {
+        out[len + i] = '=';
+    }
+
+    out[len + pad] = '\0';
+
+    return out;
+}
+
+static char*
+amqp_base64url_decode_to_string(wmem_allocator_t* pool, const char* in, size_t len)
+{
+    char* std_b64;
+    guchar* decoded;
+    gsize decoded_len;
+    char* out;
+
+    std_b64 = amqp_base64url_to_base64(pool, in, len);
+
+    decoded = g_base64_decode(std_b64, &decoded_len);
+    if (!decoded)
+        return NULL;
+
+    out = (char*)wmem_alloc0(pool, decoded_len + 1);
+    memcpy(out, decoded, decoded_len);
+    out[decoded_len] = '\0';
+
+    g_free(decoded);
+
+    return out;
+}
+
+static char*
+amqp_base64_decode_to_string(wmem_allocator_t* pool, const char* input)
+{
+    gchar* normalized;
+    guchar* decoded;
+    gsize out_len;
+    int len;
+    int i;
+    char* out;
+
+    if (!input)
+        return NULL;
+
+    len = (int)strlen(input);
+
+    /* duplicate so we can normalize URL-safe base64 */
+    normalized = g_strdup(input);
+
+    /* convert URL-safe -> standard */
+    for (i = 0; i < len; i++) {
+        if (normalized[i] == '-')
+            normalized[i] = '+';
+        else if (normalized[i] == '_')
+            normalized[i] = '/';
+    }
+
+    /* add padding if missing */
+    while ((len % 4) != 0) {
+        normalized = g_realloc(normalized, len + 2);
+        normalized[len] = '=';
+        normalized[len + 1] = '\0';
+        len++;
+    }
+
+    decoded = g_base64_decode(normalized, &out_len);
+
+    g_free(normalized);
+
+    if (!decoded || out_len == 0) {
+        if (decoded)
+            g_free(decoded);
+        return NULL;
+    }
+
+    /* make null terminated */
+    out = wmem_alloc(pool, out_len + 1);
+    memcpy(out, decoded, out_len);
+    out[out_len] = '\0';
+
+    g_free(decoded);
+
+    return out;
+}
+
+static gboolean
+amqp_looks_like_base64(const char* s)
+{
+    int len;
+    int i;
+
+    if (!s)
+        return FALSE;
+
+    len = (int)strlen(s);
+
+    /* base64 usually multiple of 4 */
+    if (len < 8)
+        return FALSE;
+
+    for (i = 0; i < len; i++) {
+        if (!(g_ascii_isalnum(s[i]) ||
+            s[i] == '+' ||
+            s[i] == '/' ||
+            s[i] == '=' ||
+            s[i] == '-' ||   /* url safe */
+            s[i] == '_'))
+            return FALSE;
+    }
+
+    return TRUE;
+}
+
+static gboolean
+amqp_looks_like_xml(const char* s)
+{
+    if (!s)
+        return FALSE;
+
+    while (*s && g_ascii_isspace(*s))
+        s++;
+
+    /* starts with <?xml ... or <tag */
+    return (*s == '<');
+}
+
+static gboolean
+amqp_looks_like_jwt_payload(const char* s)
+{
+    const char* p1;
+    const char* p2;
+
+    if (!s)
+        return FALSE;
+
+    p1 = strchr(s, '.');
+    if (!p1)
+        return FALSE;
+
+    p2 = strchr(p1 + 1, '.');
+    if (!p2)
+        return FALSE;
+
+    /* should have 3 sections */
+    if (strlen(p2 + 1) < 8)
+        return FALSE;
+
+    return TRUE;
+}
+
+static gboolean
+amqp_looks_like_text(const guint8* buf, int len)
+{
+    int i;
+    int printable = 0;
+
+    if (!buf || len <= 0)
+        return FALSE;
+
+    for (i = 0; i < len; i++) {
+
+        if (buf[i] == '\r' ||
+            buf[i] == '\n' ||
+            buf[i] == '\t') {
+            printable++;
+            continue;
+        }
+
+        if (g_ascii_isprint(buf[i]))
+            printable++;
+    }
+
+    return ((printable * 100) / len) > 90;
+}
+
+static gboolean
+amqp_looks_like_json(const char* s)
+{
+    const char* p;
+    const char* q;
+
+    if (!s)
+        return FALSE;
+
+    p = s;
+
+    while (*p && g_ascii_isspace(*p))
+        p++;
+
+    /* JSON object */
+    if (*p == '{') {
+        return (strchr(p, ':') != NULL && strchr(p, '}') != NULL);
+    }
+
+    /* JSON array */
+    if (*p == '[') {
+        q = p + 1;
+
+        while (*q && g_ascii_isspace(*q))
+            q++;
+
+        /*
+         * Reject log/timestamp style:
+         * [2026-06-26 19:01:46]
+         */
+        if (g_ascii_isdigit(*q))
+            return FALSE;
+
+        if (*q == '{' || *q == '[' || *q == '"' ||
+            *q == '-' ||
+            g_str_has_prefix(q, "true") ||
+            g_str_has_prefix(q, "false") ||
+            g_str_has_prefix(q, "null")) {
+
+            return (strchr(q, ']') != NULL);
+        }
+    }
+
+    return FALSE;
+}
+
+/*  JWT decoder                */
+
+static bool
+amqp_secret_looks_like_jwt(const char *s)
+{
+    const char *p1, *p2;
+
+    if (!s || strlen(s) < 20)
+        return false;
+
+    p1 = strchr(s, '.');
+    if (!p1)
+        return false;
+
+    p2 = strchr(p1 + 1, '.');
+    if (!p2)
+        return false;
+
+    if (strchr(p2 + 1, '.'))
+        return false;
+
+    if (strncmp(s, "eyJ", 3) != 0)
+        return false;
+
+    return true;
+}
+
+static char*
+amqp_json_get_value(wmem_allocator_t* pool, const char* json, const char* key)
+{
+    const char* p, * start, * end;
+    char pattern[128];
+
+    snprintf(pattern, sizeof(pattern), "\"%s\"", key);
+
+    p = strstr(json, pattern);
+    if (!p)
+        return NULL;
+
+    p += strlen(pattern);
+
+    while (*p && g_ascii_isspace(*p))
+        p++;
+
+    if (*p != ':')
+        return NULL;
+
+    p++;
+
+    while (*p && g_ascii_isspace(*p))
+        p++;
+
+    if (*p == '"') {
+        p++;
+        start = p;
+
+        while (*p) {
+            if (*p == '"' && *(p - 1) != '\\')
+                break;
+            p++;
+        }
+
+        return wmem_strndup(pool, start, p - start);
+    }
+
+    start = p;
+
+    while (*p && *p != ',' && *p != '}' && *p != ']')
+        p++;
+
+    end = p;
+
+    while (end > start && g_ascii_isspace(*(end - 1)))
+        end--;
+
+    return wmem_strndup(pool, start, end - start);
+}
+
+static char*
+amqp_epoch_to_local_time_string(wmem_allocator_t* pool, const char* epoch_str)
+{
+    gint64 epoch;
+    GDateTime* dt;
+    char* formatted;
+    char* out;
+
+    if (!epoch_str || !g_ascii_string_to_signed(epoch_str, 10, 0, G_MAXINT64, &epoch, NULL))
+        return NULL;
+
+    dt = g_date_time_new_from_unix_local(epoch);
+    if (!dt)
+        return NULL;
+
+    formatted = g_date_time_format(dt, "%Y-%m-%d %H:%M:%S %Z");
+    g_date_time_unref(dt);
+
+    if (!formatted)
+        return NULL;
+
+    out = wmem_strdup_printf(pool, "%s (%s)", epoch_str, formatted);
+    g_free(formatted);
+
+    return out;
+}
+
+static void
+amqp_add_json_claim(proto_tree* tree, tvbuff_t* tvb, int offset, int len,
+    int hf, const char* json, const char* key)
+{
+    char* value;
+    char* time_value;
+
+    value = amqp_json_get_value(wmem_file_scope(), json, key);
+    if (!value)
+        return;
+
+    if (g_strcmp0(key, "exp") == 0 ||
+        g_strcmp0(key, "iat") == 0 ||
+        g_strcmp0(key, "nbf") == 0) {
+
+        time_value = amqp_epoch_to_local_time_string(wmem_file_scope(), value);
+        if (time_value) {
+            proto_tree_add_string(tree, hf, tvb, offset, len, time_value);
+            return;
+        }
+    }
+
+    proto_tree_add_string(tree, hf, tvb, offset, len, value);
+}
+
+static void
+amqp_add_scope_items(proto_tree* tree, tvbuff_t* tvb, int offset, int len,
+    const char* scope)
+{
+    char** parts;
+    int i;
+
+    if (!scope)
+        return;
+
+    parts = g_strsplit(scope, " ", -1);
+
+    for (i = 0; parts[i] != NULL; i++) {
+        if (parts[i][0] == '\0')
+            continue;
+
+        proto_tree_add_string_format(tree,
+            hf_amqp_jwt_claim_scope,
+            tvb,
+            offset,
+            len,
+            parts[i],
+            "scope item: %s",
+            parts[i]);
+    }
+
+    g_strfreev(parts);
+}
